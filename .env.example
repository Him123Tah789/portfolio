# Required for all environments
DATABASE_URL="postgresql://neondb_owner:npg_29NFdqaKiDwQ@ep-shiny-feather-anlclkok-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth – generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-this-with-a-secure-random-string"
# Optional alias used by newer Auth.js naming
AUTH_SECRET="replace-this-with-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Chat mode: rules | openai | hybrid
CHAT_MODE="rules"

# OpenAI / OpenAI-compatible ChatBot
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_FALLBACK_MODEL="gpt-4.1-mini"
OPENAI_TIMEOUT_MS="30000"
OPENAI_MAX_TOKENS="350"
OPENAI_TEMPERATURE="0.3"

# Optional custom auth header (for OpenAI-compatible gateways)
OPENAI_API_KEY_HEADER="Authorization"
OPENAI_API_KEY_PREFIX="Bearer"

# Chat API rate limit (per IP)
CHAT_RATE_LIMIT_WINDOW_MS="60000"
CHAT_RATE_LIMIT_MAX="20"

# === PRODUCTION (Vercel / Railway / etc.) ===
# Replace DATABASE_URL with your production database connection string.
# For PostgreSQL on Railway:
#   DATABASE_URL="postgresql://user:password@host:port/dbname"
# For Neon:
#   DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"
#
# Set NEXTAUTH_URL to your deployed domain:
#   NEXTAUTH_URL="https://your-portfolio.vercel.app"
